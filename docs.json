            "pages": ["index", "quickstart", "getting-started/checklist", "roadmap", "community"]
          },
          {
            "group": "Contacts",
            "pages": ["contacts/overview", "contacts/upload", "contacts/lifecycle"]
          },
          {
            "group": "Campaigns",
            "pages": [
              "campaigns/overview",
              "campaigns/create",
              "campaigns/manage",
              "campaigns/analytics"
            ]
          },
          {
            "group": "Brand",
            "pages": ["brand/overview"]
          },
          {
            "group": "Dashboard",
            "pages": ["dashboard/overview"]
          },
          {
            "group": "Settings",
            "pages": [
              "settings/account",
              "settings/team",
              "settings/signatures"
            ]
          },
          {
            "group": "Billing",
            "pages": ["billing/overview"]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/contact-lifecycle",
              "concepts/workspaces-and-roles",
              "concepts/deliverability-basics",
              "concepts/developers-and-apis"
            ]
          },
          {
            "group": "Troubleshooting & FAQ",
            "pages": [
              "troubleshooting/index",
              "troubleshooting/deliverability",
              "troubleshooting/billing",
              "troubleshooting/access"
            ]
          },
          {
            "group": "Security & privacy",
            "pages": ["security/privacy-and-data"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "href": "https://nudgen.net",
          "icon": "house"
        },
        {
          "anchor": "Pricing",
          "href": "https://nudgen.net/pricing",
          "icon": "tag"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/logo-light.svg",
    "dark": "/logo/logo-dark.svg",
    "href": "https://nudgen.net"
  },
  "navbar": {
    "links": [
      {
        "label": "Pricing",
        "href": "https://nudgen.net/pricing"
      },
      {
        "label": "Contact",
